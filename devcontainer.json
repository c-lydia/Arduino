{
    "name": "PlatformIO via Compose",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "platformio",
    "workspaceFolder": "/workspace",
    "customizations": {
        "vscode": {
            "extensions": [
                "platformio.platformio-ide",
                "ms-vscode.cpptools"
            ]
        }
    },
    "remoteUser": "root"
}